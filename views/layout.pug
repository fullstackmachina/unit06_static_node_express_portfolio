<!DOCTYPE html>
html(lang="en" dir="ltr")
  head
    meta(charset='utf-8')
    meta(http-equiv='x-ua-compatible', content='ie=edge')
    meta(name='viewport', content='width=device-width, initial-scale=1.0')
    title Portfolio Site
    link(href='https://fonts.googleapis.com/css?family=Merriweather:300,400,400i,700,800', rel='stylesheet')
    link(rel='stylesheet', href='/static/css/normalize.css')
    link(rel='stylesheet', href='/static/css/styles.css')

  body
    #my-info.sidebar
      .sidebar-info-box
        br
        .thumbnail-box
          img.thumbnail(src='/images/profile.webp', alt='My profile photo')
        .dev-intro-box
          h5.sidebar-tagline
            | Hello World, I'm 
            span.sidebar-tagline-accent Rox
            |  !

        nav.sidebar-nav
          a.sidebar-link(href='/about') About me
          a.sidebar-link(href='/') My projects
          a.sidebar-link(href='/future_projects') Future projects
          a.sidebar-link(href='/releases') Releases and updates

    .wrapper
      .header
        .header-info-box
          button#menu-icon.menu-icon(type='button' data-toggle='my-info')
          span Hello World, I'm Rox !

      block content

  script(src='/static/js/script.js')
